# ============================================
# CORE SETTINGS
# ============================================
ENV=prod
DOCKER=true
PORT=8080

# ============================================
# WEBUI CONFIGURATION
# ============================================
WEBUI_NAME=Open Connect
WEBUI_URL=https://open-connect-production.up.railway.app
WEBUI_SECRET_KEY=your-secret-key-here
WEBUI_AUTH=true
ENABLE_SIGNUP=true
ENABLE_API_KEYS=true

# ============================================
# OLLAMA CONFIGURATION
# ============================================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_API_BASE_URL=http://localhost:11434/api
ENABLE_OLLAMA_API=true

# ============================================
# OPENAI/EXTERNAL API CONFIGURATION
# ============================================
# OpenRouter API (with Google Vertex AI integration)
OPENAI_API_KEY=your-openrouter-api-key
OPENAI_API_BASE_URL=https://openrouter.ai/api/v1

# Default Models (Free OpenRouter Models)
DEFAULT_MODELS=google/gemma-3-4b-it,qwen/qwen-2.5-7b-instruct,microsoft/phi-4,deepseek/deepseek-r1,anthropic/claude-3.5-haiku,meta/llama-3.1-8b-instruct

# ============================================
# GOOGLE GEMINI / VERTEX AI
# ============================================
# Set either GEMINI_API_KEY or GOOGLE_API_KEY for Google Gemini (AI Studio).
GEMINI_API_KEY=your-gemini-api-key
GOOGLE_API_KEY=your-gemini-api-key
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/google-vertex.json
GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account",...}

# ============================================
# LANGCHAIN / LANGSMITH WORKSPACE TRACING
# ============================================
LANGSMITH_API_KEY=your-langsmith-api-key
LANGSMITH_PROJECT=open-connect
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_TRACING=true
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=open-connect
LANGCHAIN_VERBOSE=false

# ============================================
# ADDITIONAL AI PROVIDERS
# ============================================
HUGGINGFACE_TOKEN=your-huggingface-token
HF_TOKEN=your-huggingface-token
HUGGING_FACE_HUB_TOKEN=your-huggingface-token
USER_AGENT=Open Connect/1.0 (+https://github.com/OrgHide/open-connect)
GROQ_API_KEY=your-groq-api-key

# ============================================
# DATABASE CONFIGURATION
# ============================================
# SQLite (default) - leave empty to use SQLite
# DATABASE_URL=sqlite:///app/backend/data/webui.db

# PostgreSQL/Supabase (production)
# DATABASE_URL=postgresql://postgres:password@host:5432/database

# ============================================
# REDIS CONFIGURATION
# ============================================
# Use your Redis Cloud connection string here (rediss:// for TLS).
# REDIS_URL=rediss://default:password@host:port/0
# WEBSOCKET_REDIS_URL=rediss://default:password@host:port/0
# REDIS_CLUSTER=false
# WEBSOCKET_MANAGER=redis
# WEBSOCKET_REDIS_CLUSTER=false
# REDIS_KEY_PREFIX=open-webui

# ============================================
# SUPABASE CONFIGURATION
# ============================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================
# WEB SEARCH CONFIGURATION
# ============================================
WEB_SEARCH=true
WEB_SEARCH_CONFIRMATION=true
WEB_SEARCH_BYPASS_EMBEDDING=true

# ============================================
# CODE EXECUTION
# ============================================
CODE_EXECUTION=true
CODE_INTERPRETER=true

# ============================================
# RAG/VECTOR SEARCH
# ============================================
RAG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAG_TOP_K=5
RAG_RELEVANCE_THRESHOLD=0.5

# Qdrant Vector Database (Optional)
# QDRANT_URL=https://your-qdrant-cloud.com
# QDRANT_API_KEY=your-qdrant-api-key
# RAG_HYBRID_SEARCH=true

# ============================================
# WHISPER (SPEECH TO TEXT)
# ============================================
WHISPER_MODEL=base

# ============================================
# FEATURE FLAGS
# ============================================
ENABLE_MEMORIES=true
ENABLE_NOTES=true
ENABLE_AUTOMATIONS=true
ENABLE_MESSAGE_RATING=true
ENABLE_FOLDERS=true
ENABLE_CHANNELS=true
ENABLE_MODELS=true
ENABLE_DIRECT_CONNECTIONS=true
CACHE_BASE_MODEL_LIST=true

# ============================================
# JWT/AUTH CONFIGURATION
# ============================================
JWT_EXPIRY=4w

# ============================================
# CORS CONFIGURATION
# ============================================
CORS_ALLOW_ORIGIN=*

# ============================================
# FILE UPLOAD
# ============================================
MAX_FILE_UPLOAD_SIZE=100

# ============================================
# TASK CONFIGURATION
# ============================================
TASK_MODEL=google/gemma-3-4b-it
TASK_MODEL_EXTERNAL=google/gemma-3-4b-it

# ============================================
# AUDIO CONFIGURATION
# ============================================
AUDIO_TTS_ENABLED=true
AUDIO_STT_ENABLED=true

# ============================================
# LOGGING
# ============================================
GLOBAL_LOG_LEVEL=INFO
LOG_LEVEL=INFO

# DO NOT TRACK
SCARF_NO_ANALYTICS=true
DO_NOT_TRACK=true
ANONYMIZED_TELEMETRY=false

# For production you should set this to match the proxy configuration
FORWARDED_ALLOW_IPS='*'
