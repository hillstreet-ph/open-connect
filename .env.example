# OPEN-CONNECT ENVIRONMENT CONFIGURATION
# ============================================================================
# Copy this to .env and fill in your actual credentials
# NEVER commit .env to version control!
# Store actual values in GitHub Secrets
# ============================================================================

# ============================================================================
# SUPABASE CONFIGURATION
# ============================================================================
SUPABASE_URL=https://rxpkxtzzkvwgjtbtcctc.supabase.co
SUPABASE_REST_URL=https://rxpkxtzzkvwgjtbtcctc.supabase.co/rest/v1/
SUPABASE_PROJECT_REF=rxpkxtzzkvwgjtbtcctc
SUPABASE_ANON_KEY=${{ secrets.SUPABASE_ANON_KEY }}
SUPABASE_SERVICE_ROLE_KEY=${{ secrets.SUPABASE_SERVICE_ROLE_KEY }}
SUPABASE_PASSWORD=${{ secrets.SUPABASE_PASSWORD }}
SUPABASE_DB_URL=postgresql://postgres:${{ secrets.SUPABASE_PASSWORD }}@aws-0-ap-northeast-1.pooler.supabase.co:5432/postgres

# ============================================================================
# RAILWAY CONFIGURATION
# ============================================================================
RAILWAY_TOKEN=${{ secrets.RAILWAY_TOKEN }}
RAILWAY_PROJECT_ID=open-connect

# ============================================================================
# GITHUB CONFIGURATION
# ============================================================================
GITHUB_TOKEN=${{ secrets.GITHUB_TOKEN }}
GH_REPOSITORY=OrgHide/open-connect

# ============================================================================
# DOCKER CONFIGURATION
# ============================================================================
DOCKER_HUB_USERNAME=openclose8
DOCKER_HUB_TOKEN=${{ secrets.DOCKER_HUB_TOKEN }}

# ============================================================================
# REDIS CONFIGURATION
# ============================================================================
REDIS_URL=redis://:${{ secrets.REDIS_PASSWORD }}@open-authentic-megasoft-40561.db.redis.io:12264
REDIS_PASSWORD=${{ secrets.REDIS_PASSWORD }}

# ============================================================================
# AWS S3 / SUPABASE STORAGE
# ============================================================================
AWS_S3_BUCKET=open-connect-backups
SUPABASE_STORAGE_URL=https://rxpkxtzzkvwgjtbtcctc.storage.supabase.co/storage/v1/s3
AWS_ACCESS_KEY_ID=${{ secrets.AWS_ACCESS_KEY_ID }}
AWS_SECRET_ACCESS_KEY=${{ secrets.AWS_SECRET_ACCESS_KEY }}
AWS_REGION=ap-northeast-1

# ============================================================================
# EXTERNAL AI SERVICES
# ============================================================================
OPENROUTER_API_KEY=${{ secrets.OPENROUTER_API_KEY }}
HUGGINGFACE_TOKEN=${{ secrets.HUGGINGFACE_TOKEN }}
GEMINI_API_KEY=${{ secrets.GEMINI_API_KEY }}
GOOGLE_VERTEX_KEY=${{ secrets.GOOGLE_VERTEX_KEY }}

# ============================================================================
# LANGFUSE OBSERVABILITY
# ============================================================================
LANGFUSE_PUBLIC_KEY=${{ secrets.LANGFUSE_PUBLIC_KEY }}
LANGFUSE_SECRET_KEY=${{ secrets.LANGFUSE_SECRET_KEY }}
LANGFUSE_HOST=http://open-connect-langfuse:3000

# ============================================================================
# ONE PLANE CREDENTIALS VAULT
# ============================================================================
ONE_PLANE_WORKSPACE_ID=${{ secrets.ONE_PLANE_WORKSPACE_ID }}
ONE_PLANE_API_KEY=${{ secrets.ONE_PLANE_API_KEY }}

# ============================================================================
# REDIS AI SERVICES
# ============================================================================
REDIS_AI_APIKEY=${{ secrets.REDIS_AI_APIKEY }}
REDIS_STORE_ID=3098e57337474bb39ae5279ae2781cdc
REDIS_ENDPOINT_ID=https://gcp-us-east4.memory.redis.io
REDIS_LANGCACHE_APIKEY=${{ secrets.REDIS_LANGCACHE_APIKEY }}
REDIS_LANGCACHE_CACHE_ID=d739b84cee624ff5a2003577a2e080de

# ============================================================================
# SECURITY SECRETS
# ============================================================================
SESSION_SECRET=${{ secrets.SESSION_SECRET }}
NEXTAUTH_SECRET=${{ secrets.NEXTAUTH_SECRET }}
JWT_SECRET=${{ secrets.JWT_SECRET }}
SALT=${{ secrets.SALT }}
ENCRYPTION_KEY=${{ secrets.ENCRYPTION_KEY }}

# ============================================================================
# NOTIFICATIONS
# ============================================================================
SLACK_WEBHOOK=${{ secrets.SLACK_WEBHOOK }}
EMAIL_ALERTS=admin@orghide.com
PAGERDUTY_KEY=${{ secrets.PAGERDUTY_KEY }}

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
NODE_ENV=production
PORT=3000
ORIGIN=https://open-connect.up.railway.app
